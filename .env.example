# ─── Minerva root env (compose reads this) ─────────────────────────────
# Copy to .env and fill in. Blank keys are fine until the milestone that needs them.

# Postgres (pgvector) — used by docker-compose and by DATABASE_URL below
POSTGRES_USER=minerva
POSTGRES_PASSWORD=minerva
POSTGRES_DB=minerva

# Backend
# When running api on host against the compose db, host is localhost:5432.
# When running api inside compose, host is the service name `db`.
DATABASE_URL=postgresql://minerva:minerva@localhost:5432/minerva?schema=public
JWT_SECRET=change-me-in-production

# LLM / embeddings (needed M2 / M3)
ANTHROPIC_API_KEY=
VOYAGE_API_KEY=

# LINE (needed M1 webhook / M2 send)
LINE_CHANNEL_ACCESS_TOKEN=
LINE_CHANNEL_SECRET=
# Outbound-only owner channel. Blank token = owner pushes skip; never fall back to Prominent.
APPDENT_LINE_CHANNEL_ACCESS_TOKEN=
APPDENT_OWNER_LINE_USER_ID=
# Staff-only Mali LINE OA. Leave either blank to disable /webhook/mali safely.
MALI_LINE_CHANNEL_ACCESS_TOKEN=
MALI_LINE_CHANNEL_SECRET=
# Set to 1 to never actually push to LINE (logs instead) — safe for testing.
LINE_DRY_RUN=

# Pipeline tuning (spec §13)
RECENT_WINDOW=10
RETRIEVE_K=3
SESSION_IDLE_MINUTES=30
MALI_DAILY_LIMIT=30
MALI_MIN_SIMILARITY=0.55

# Server
PORT=3000
NODE_ENV=development
WEB_ORIGIN=http://localhost:5173,http://localhost:5175,http://localhost:5176

# Ceres local-login compatibility window (GET /api/ceres/logins for ?local=1).
# Leave true for the first portal-only release, then flip false after observation.
CERES_LOCAL_LOGIN_ENABLED=true

# Diana / Juno static bundles: public URL of the api, baked at build (compose build args)
DIANA_API_URL=http://localhost:3000
JUNO_API_URL=http://localhost:3000
