# ─── api env (used when running api on the host, outside compose) ──────
# Copy to api/.env. For host runs the db is on localhost:5432.
DATABASE_URL=postgresql://minerva:minerva@localhost:5432/minerva?schema=public
JWT_SECRET=change-me-in-production

ANTHROPIC_API_KEY=
VOYAGE_API_KEY=
LINE_CHANNEL_ACCESS_TOKEN=
LINE_CHANNEL_SECRET=
# Outbound-only owner channel. Blank token = owner pushes skip; never fall back to Prominent.
APPDENT_LINE_CHANNEL_ACCESS_TOKEN=
APPDENT_OWNER_LINE_USER_ID=
# Staff-only Mali LINE OA. Leave either blank to disable /webhook/mali safely.
MALI_LINE_CHANNEL_ACCESS_TOKEN=
MALI_LINE_CHANNEL_SECRET=
# Set to 1 to never actually push to LINE (logs instead) — safe for testing.
LINE_DRY_RUN=

RECENT_WINDOW=10
RETRIEVE_K=3
SESSION_IDLE_MINUTES=30
DRAFT_IMAGE_MAX=3
DRAFT_IMAGE_MAX_BYTES=3750000
MALI_DAILY_LIMIT=30
MALI_MIN_SIMILARITY=0.55

PORT=3000
NODE_ENV=development
WEB_ORIGIN=http://localhost:5173

# Rollback only; leave blank to reject old non-expiring Ceres receipt links.
CERES_ALLOW_LEGACY_MEDIA_TOKENS=
# Compatibility window only. Default true for the first portal-only release; set false to
# remove GET /api/ceres/logins after readiness and sign-in observation are complete.
CERES_LOCAL_LOGIN_ENABLED=true
