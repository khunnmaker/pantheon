# ─── api env (used when running api on the host, outside compose) ──────
# Copy to api/.env. For host runs the db is on localhost:5432.
DATABASE_URL=postgresql://minerva:minerva@localhost:5432/minerva?schema=public
JWT_SECRET=change-me-in-production

ANTHROPIC_API_KEY=
VOYAGE_API_KEY=
LINE_CHANNEL_ACCESS_TOKEN=
LINE_CHANNEL_SECRET=
# Set to 1 to never actually push to LINE (logs instead) — safe for testing.
LINE_DRY_RUN=

RECENT_WINDOW=10
RETRIEVE_K=3
SESSION_IDLE_MINUTES=30

PORT=3000
NODE_ENV=development
WEB_ORIGIN=http://localhost:5173
