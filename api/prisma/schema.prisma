// Minerva — Prisma schema.
//
// SCOPE: M0–M2 are RELATIONAL ONLY and run on any vanilla PostgreSQL.
// pgvector (embeddings/retrieval) is NOT used until M3, so the vector extension
// and the two embedding tables are deferred — see the commented-out block at the
// bottom of this file and prisma/init-pgvector.sql. Activate them in M3 once the
// db has the `vector` extension available (docker-compose uses pgvector/pgvector).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Customer {
  id                String          @id @default(cuid())
  lineUserId        String          @unique
  displayName       String?
  // LINE profile/group picture (public https url from getProfile/getGroupSummary); null when
  // none or unavailable. Best-effort — set on customer creation + lazily on chat-open.
  pictureUrl        String?
  // when pictureUrl was last fetched from LINE; throttles the periodic refresh (PICTURE_REFRESH_DAYS)
  // so an active customer's changed photo is picked up without hammering the LINE API. null = never.
  pictureFetchedAt  DateTime?
  // staff-assigned nickname (shown in the console in preference to the LINE name)
  nickname          String?
  // staff-assigned customer code from the Express system (shown before the name, e.g. ร103)
  code              String?
  // staff-assigned area/type category (e.g. C1–C6 by zone, Lab) — one per customer
  category          String?
  // sales-pipeline stage (ถาม/สั่งซื้อ/ส่ง/ดูแล/เสร็จ/ยกเลิก) — staff-confirmed
  stage             String?
  // the AI's pending stage suggestion; staff accept → stage. null = none/already accepted
  suggestedStage    String?
  // "ตอบแล้ว" cutoff: messages at/before this are handled (e.g. answered on LINE OA
  // directly). The AI drafts only from messages AFTER it, and the chat is not "waiting".
  answeredThroughAt DateTime?
  firstSeen         DateTime        @default(now())
  lastSeen          DateTime        @default(now())
  // legacy hide flag (the old "จบแชท" set it false). "ตอบแล้ว" no longer hides — chats stay
  // visible and just leave the waiting queue via answeredThroughAt. New messages set it true.
  active            Boolean         @default(true)
  messages          Message[]
  memory            CustomerMemory?
  sessions          Session[]
}

model Session {
  id         String    @id @default(cuid())
  customerId String
  customer   Customer  @relation(fields: [customerId], references: [id])
  status     String    @default("open") // open | ended
  startedAt  DateTime  @default(now())
  endedAt    DateTime?
  messages   Message[]
}

model Message {
  id               String    @id @default(cuid())
  customerId       String
  sessionId        String?
  role             String // customer | agent
  text             String
  agentId          String? // who sent (if agent)
  kbIds            String[] // KB entries used
  channelMsgId     String? // LINE message id
  // For agent replies: the customer message this answers. Unique → a customer
  // message can be answered exactly once (idempotent/replay-safe send).
  answersMessageId String?   @unique
  // Non-text messages: "image" | "sticker" | "video" | "audio" | "file" | "location" | "product".
  // attachmentRef holds the stored content-type, "packageId/stickerId" for stickers,
  // or the catalog photoSku for an agent "product" reply.
  attachmentType   String?
  attachmentRef    String?
  // original filename for received "file" messages (for download).
  attachmentName   String?
  // Short AI-generated description used to make customer images meaningful in later history.
  aiCaption        String?
  // LINE quote-reply support. quoteToken = LINE's token to quote THIS message in a later
  // send (issued only for inbound text/sticker; never exposed to the client). quotedMessageId
  // = OUR internal Message.id this message is a reply to (resolved at write time), for both an
  // incoming customer quote-reply and our own quote-reply out.
  quoteToken       String?
  quotedMessageId  String?
  // when a payment-slip image was forwarded to finance (the Google Sheet) — also blocks double-send.
  financeSentAt    DateTime?
  // the amount the AI OCR read off the slip (server-set, tamper-proof) — compared to the
  // staff-entered amount on forward; a mismatch is logged to the admin audit report.
  slipAmount       String?
  createdAt        DateTime  @default(now())

  customer Customer @relation(fields: [customerId], references: [id])
  session  Session? @relation(fields: [sessionId], references: [id])
  // embedding MessageEmbedding?  // M3 — see deferred block below

  @@index([customerId])
  @@index([sessionId])
}

model CustomerMemory {
  customerId         String   @id
  customer           Customer @relation(fields: [customerId], references: [id])
  summary            String   @default("")
  summarizedThroughN Int      @default(0) // message count covered by summary
  updatedAt          DateTime @updatedAt
}

// Per-agent private "pin chat": a sales agent pins customer chats they're working on
// so their in-progress deals stay one click away, in a "ปักหมุด" section at the top of
// the console queue. Private (keyed by agentId), manual unpin only. Bare String ids —
// no @relation — matching the house cross-reference style (e.g. Message.agentId).
model Pin {
  id         String   @id @default(cuid())
  agentId    String
  customerId String
  createdAt  DateTime @default(now())

  @@unique([agentId, customerId])
  @@index([agentId])
}

model Agent {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String
  role         String   @default("agent") // agent | supervisor
  authVersion  Int      @default(0)
  createdAt    DateTime @default(now())
  // Per-person app grants ('minerva'|'vesta'|'juno'|'ceres'|'apollo'); supervisor/gm access is
  // implicit by role, this list matters only for role 'employee'. Edited later by Jupiter's
  // admin UI — boot-sync must never overwrite it (create-only default).
  apps         String[] @default([])
  lineUserId   String?  @unique
  lineBindCode String?  @unique

  apolloProjectMemberships ApolloProjectMember[]
  apolloCreatedProjects    ApolloProject[]       @relation("ApolloProjectCreator")
  apolloCreatedTasks       ApolloTask[]          @relation("ApolloTaskCreator")
  apolloAssignedTasks      ApolloTask[]          @relation("ApolloTaskAssignee")
  apolloComments           ApolloComment[]
  apolloAttachments        ApolloAttachment[]
  apolloEvents             ApolloEvent[]
}

// ─── Apollo: employee work management ──────────────────────────────────────

model ApolloProject {
  id          String                @id @default(cuid())
  name        String
  color       String                @default("#4f46e5")
  columns     String[]              @default(["To do", "Doing", "Done"])
  archived    Boolean               @default(false)
  createdById String
  createdBy   Agent                 @relation("ApolloProjectCreator", fields: [createdById], references: [id])
  members     ApolloProjectMember[]
  tasks       ApolloTask[]
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt

  @@index([archived])
}

model ApolloProjectMember {
  id        String        @id @default(cuid())
  projectId String
  project   ApolloProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  agentId   String
  agent     Agent         @relation(fields: [agentId], references: [id], onDelete: Cascade)
  createdAt DateTime      @default(now())

  @@unique([projectId, agentId])
  @@index([agentId])
}

model ApolloTask {
  id             String             @id @default(cuid())
  projectId      String
  project        ApolloProject      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title          String
  notes          String             @default("")
  assigneeId     String?
  assignee       Agent?             @relation("ApolloTaskAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  creatorId      String
  creator        Agent              @relation("ApolloTaskCreator", fields: [creatorId], references: [id])
  dueDate        DateTime           @db.Date
  priority       String             @default("normal")
  status         String
  customerRef    String?
  recurrenceRule Json?
  seriesId       String?
  sortOrder      Float              @default(0)
  completedAt    DateTime?
  comments       ApolloComment[]
  attachments    ApolloAttachment[]
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  @@unique([seriesId, dueDate])
  @@index([projectId, status, sortOrder])
  @@index([assigneeId, completedAt, dueDate])
  @@index([seriesId, completedAt])
}

model ApolloComment {
  id        String     @id @default(cuid())
  taskId    String
  task      ApolloTask @relation(fields: [taskId], references: [id], onDelete: Cascade)
  authorId  String
  author    Agent      @relation(fields: [authorId], references: [id])
  body      String
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@index([taskId, createdAt])
}

model ApolloAttachment {
  id           String     @id @default(cuid())
  taskId       String
  task         ApolloTask @relation(fields: [taskId], references: [id], onDelete: Cascade)
  uploadedById String
  uploadedBy   Agent      @relation(fields: [uploadedById], references: [id])
  uploadId     String     @unique
  fileName     String
  contentType  String
  kind         String
  size         Int
  createdAt    DateTime   @default(now())

  @@index([taskId, createdAt])
}

// Personal event on a member's own calendar (นัดหมอ, ธุระส่วนตัว) — see docs/APOLLO_EVENTS
// spec. `visibility` gates who sees title/note beyond the owner: 'private' (default) limits
// that to the owner and role 'supervisor' (the CEO) — every other viewer, GM users included (NO
// role bypass via the manager() helper), only ever gets an anonymous "ไม่ว่าง" busy block;
// 'public' shows title/note to everyone. Enforced by masking in apollo/calendarQuery.ts's
// maskEvent, never by hiding rows here. onDelete: Cascade so a removed Agent takes their
// events with them (unlike ApolloTask.assignee, which just SetNulls — an orphaned personal
// event owned by nobody has no meaning).
model ApolloEvent {
  id         String    @id @default(cuid())
  agentId    String
  agent      Agent     @relation(fields: [agentId], references: [id], onDelete: Cascade)
  title      String
  note       String    @default("")
  date       DateTime  @db.Date
  endDate    DateTime? @db.Date // multi-day span end (inclusive); null = single-day event
  startTime  String? // wall-clock "HH:MM", optional
  endTime    String? // wall-clock "HH:MM", optional — requires startTime, must be later
  visibility String    @default("public") // 'private' | 'public' — see calendarQuery.ts maskEvent
  // Recurrence v1 — same rule vocabulary as ApolloTask (see recurrence.ts): expanded server-side
  // in calendarQuery.ts, NOT stored as separate rows. `date` is the first occurrence; the rule's
  // weekday/dayOfMonth must match it (enforced in buildEventData). A rule and endDate can't
  // coexist (one-day-per-occurrence). recurrenceUntil is the last date an occurrence may fall on
  // (inclusive; null = forever). skipDates holds 'YYYY-MM-DD' occurrences deleted individually via
  // the skip route — never touched by PATCH (not in eventBody), so a whole-series edit keeps them.
  recurrenceRule  Json?
  recurrenceUntil DateTime? @db.Date
  skipDates       String[]  @default([])
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([agentId, date])
  @@index([date])
}

model KbEntry {
  id               String   @id @default(cuid())
  category         String
  questionVariants String[]
  answer           String
  sku              String?
  sensitivity      String   @default("normal") // normal | price_stock | clinical | no_auto
  status           String   @default("active") // active | pending | archived
  source           String   @default("manual") // manual | learned
  lastVerifiedAt   DateTime @default(now())
  ownerAgentId     String?
  // embedding KbEmbedding?  // M3 — see deferred block below
}

model LearnedAnswer {
  id               String   @id @default(cuid())
  customerQuestion String
  aiDraft          String
  finalAnswer      String
  agentId          String
  edited           Boolean  @default(true)
  status           String   @default("pending") // pending | flagged | promoting | resolving | approved | rejected
  flagNote         String?
  promotedKbId     String?
  createdAt        DateTime @default(now())
}

model Draft {
  id              String   @id @default(cuid())
  messageId       String   @unique // the customer message it answers
  type            String // draft | needs_human | out_of_scope
  draftText       String
  usedKb          String[]
  note            String?
  retrievedMsgIds String[]
  // catalog product this draft is about — its photo is attached on send (M4)
  productSku      String?
  // candidate product SKUs (with photos) for staff to choose from when unsure
  candidateSkus   String[]
  // AI-suggested cross-sell/complementary product SKUs (with photos)
  crossSellSkus   String[]
  createdAt       DateTime @default(now())
}

// Learned cross-sell relationship: when a customer asks about anchorSku, how good
// is crossSku as an add-on? score rises when staff attach it, falls when it's shown
// but skipped — so good pairings surface and ignored ones fade.
model CrossSellLink {
  id          String   @id @default(cuid())
  anchorSku   String
  crossSku    String
  score       Int      @default(0)
  shownCount  Int      @default(0)
  chosenCount Int      @default(0)
  updatedAt   DateTime @updatedAt

  @@unique([anchorSku, crossSku])
  @@index([anchorSku])
}

// Team-taught keyword→product links: when staff manually pick a product (via search)
// as the MAIN answer for a customer question, that question's keywords are strengthened
// against the product so findProducts surfaces it for similar questions next time.
model ProductKeyword {
  id        String   @id @default(cuid())
  sku       String
  keyword   String // a normalized token from a customer question
  score     Int      @default(1)
  updatedAt DateTime @updatedAt

  @@unique([sku, keyword])
  @@index([keyword])
}

// Tamper-proof audit of staff-CORRECTED payment amounts. The OCR amount is server-set;
// when staff forward a different amount, a row is logged HERE (not a sheet sales can edit)
// and shown only to supervisors for verification.
model FinanceAudit {
  id           String    @id @default(cuid())
  messageId    String // the payment-slip message
  customerId   String
  nickname     String    @default("")
  senderName   String    @default("") // name read off the slip
  ocrAmount    String    @default("") // amount the AI read off the slip (server truth)
  amount       String    @default("") // amount the staff actually submitted
  diff         String    @default("")
  salesName    String    @default("")
  salesAgentId String?
  resolvedAt   DateTime? // a supervisor marked it verified
  resolvedById String?
  createdAt    DateTime  @default(now())

  @@index([resolvedAt])
}

// Juno (finance) — the structured record of every INCOMING payment. Most rows are written
// by Minerva's /to-finance hook (mirrors the Google-Sheet forward, source='line'); FIN/CEO
// can also hand-add a row in Juno itself (source='manual_transfer'|'cash'|'cheque' — see
// JUNO_MANUAL_ENTRY_BRIEF.md). The finance department works off THIS table via the Juno app,
// never the sheet. INCOME only for now; expenses and Express/Odoo sync are deliberately out
// of scope (future, same table). Customer name/code are SNAPSHOT here so history stays stable
// if the Customer is renamed.
model Payment {
  id               String             @id @default(cuid())
  // link + snapshot
  customerId       String?
  customerCode     String             @default("") // e.g. ร001 (join key across the Deities)
  customerName     String             @default("") // "ชื่อ": assigned nickname else LINE name, at time of payment
  senderName       String             @default("") // "ชื่อผู้โอน": the name parsed off the slip
  // money (String to match the free-text OCR/entry flow; sums parse on read)
  amount           String             @default("") // confirmed baht amount (staff-entered)
  ocrAmount        String             @default("") // what the OCR read (for the mismatch flag)
  // withholding tax (หัก ณ ที่จ่าย, task 2). CORRECTED MODEL: `amount` above is the NET received
  // (exactly what the slip/bank shows); the GROSS / RE figure = amount + whtAmount. The bank
  // matcher compares `amount` DIRECTLY to the credit (no netOf subtraction). whtRate 0 /
  // whtAmount "" = no WHT (the default for every existing + non-WHT row). Entered in the
  // ตรวจแล้ว (RE-check) dialog; whtRate ∈ {0,1,2,3,5} (percent), whtAmount is the editable baht
  // figure (may differ slightly from a naive rate×gross calc to match the 50-ทวิ certificate).
  whtRate          Int                @default(0)
  whtAmount        String             @default("")
  bank             String             @default("") // account received into
  transferAt       String             @default("") // when the customer transferred (as-shown on slip)
  ref              String             @default("") // transfer reference no.
  // the slip itself
  slipMessageId    String?            @unique // the Minerva Message this came from — one Payment per slip (idempotent re-forward)
  slipUrl          String             @default("") // tokenized public link to the slip image (Minerva hosts it)
  // tax invoice
  taxInvoice       String             @default("") // ใบกำกับภาษี: name / address / tax-id (free text), blank if not requested
  taxInvoiceStatus String             @default("none") // none | requested | issued
  // who forwarded it (sales)
  salesAgentId     String?
  salesName        String             @default("")
  note             String             @default("") // หมายเหตุ
  // finance lifecycle (Juno owns this)
  status           String             @default("received") // received | verified | recorded | void
  flagged          Boolean            @default(false) // true when ocrAmount != amount, or raised by finance
  verifiedById     String? // finance user who last advanced it
  verifiedAt       DateTime?
  createdAt        DateTime           @default(now()) // when Minerva forwarded it
  // FIN check data (entered in Juno's check dialog when the RE is issued in Express)
  // DEPRECATED: kept only as a join mirror = reNumbers.join('/'), for back-compat search
  // (buildListWhere's `contains` filter) and the CSV export column. Never write it directly —
  // always derive it from reNumbers. See reNumbers below for the real (list) source of truth.
  reNumber         String             @default("") // receipt no.(s), bare 7 digits, joined with '/' if >1
  // one payment can cover several REs (e.g. one transfer paying several receipts); one RE can
  // also be split across several payments — so this is a plain list, not a relation. Each entry
  // is bare 7 digits (see POST /verify's normalization).
  reNumbers        String[]           @default([])
  billNos          String[]           @default([])
  receiptName      String             @default("") // official name on the RE (may differ from customerName)
  customerType     String             @default("") // โอนก่อนส่ง | เครดิต | เก็บปลายทาง | "" (unset)
  // bank reconciliation (phase B): denormalized true while >=1 PaymentBankMatch link exists
  reconciled       Boolean            @default(false)
  bankMatches      PaymentBankMatch[]
  // how the row entered Juno. 'line' = Minerva LINE slip (default, all existing rows);
  // the rest are hand-added in Juno. transfer types reconcile in กระทบยอด; cash/cheque
  // are verified in the เงินสด/เช็ค tab instead.
  source           String             @default("line") // line | manual_transfer | cash | cheque
  // cash/cheque banking state (blank for transfers). cash: '' -> deposited; cheque: '' -> cleared.
  settleState      String             @default("") // '' | deposited | cleared
  settledAt        DateTime?
  settledById      String?
  // CEO receipt-verify gate (task 1) — SEPARATE from settleState above: the CEO must confirm he
  // physically received the cash/cheque before it can be ยืนยันใน Express (status->'recorded').
  // null = not yet confirmed. A cheque's KBiz auto-clear (settleState->'cleared') is a separate
  // banking event and does NOT set these — only POST /payments/:id/receive (supervisor-only) does.
  receivedAt       DateTime?
  receivedBy       String?
  // Payment discrepancy ledger: FIN may override the RE-derived expected gross, records a
  // resolution, and the CEO confirms it. Empty strings mean unset; computed diff stays live.
  discExpected     String             @default("")
  discResolution   String             @default("")
  discNote         String             @default("")
  discResolvedAt   DateTime?
  discResolvedBy   String             @default("")
  discConfirmedAt  DateTime?
  discConfirmedBy  String             @default("")
  // cheque details (source='cheque' only)
  chequeNo         String             @default("")
  chequeBank       String             @default("")
  chequeDueDate    String             @default("") // as-typed (free text, like transferAt)

  @@index([status])
  @@index([flagged])
  @@index([taxInvoiceStatus])
  @@index([customerCode])
  @@index([createdAt])
  @@index([reNumber])
  @@index([reconciled])
  @@index([source])
  @@index([settleState])
}

// ─── Juno phase B (bank import + reconciliation) ─────────────────────────
// The owner downloads two bank exports every Wed/Sat — KBIZ (Kasikorn business
// statement CSV) and K SHOP (merchant app report) — and Juno reconciles their
// credit lines against checked (RE-carrying) Payments. See JUNO_PROCESS_BRIEF.md
// PHASE B. Matching is many-to-many (one credit can pay many REs; one RE can be
// paid by two transfers), hence the join table rather than a FK on either side.

// Audit row for each bank-file import (preview→apply, mirrors Vesta's StockImport).
model BankImport {
  id           String   @id @default(cuid())
  source       String // kbiz | kshop
  fileName     String   @default("")
  importedAt   DateTime @default(now())
  importedBy   String?
  rowsParsed   Int      @default(0)
  txnsNew      Int      @default(0)
  txnsDup      Int      @default(0) // already in DB (overlapping Wed/Sat export ranges are NORMAL)
  txnsExcluded Int      @default(0) // K SHOP settlement lump, voids, balance rows
  note         String   @default("")
}

// One bank line (KBIZ statement row or K SHOP transaction row). dedupeKey makes
// re-importing an overlapping export range a no-op instead of a duplicate.
model BankTxn {
  id                   String             @id @default(cuid())
  source               String // kbiz | kshop
  txnAt                DateTime
  amount               String             @default("") // baht "1234.56" (house String style, matches Payment.amount)
  direction            String             @default("in") // in | out
  channel              String             @default("")
  description          String             @default("") // KBIZ Descriptions / kshop "Payment"
  details              String             @default("") // KBIZ Details / kshop payer·bank·terminal
  payerName            String             @default("")
  payerBank            String             @default("")
  dedupeKey            String             @unique // sha256("source|txnAt ISO|amount|details"), "|n" suffix on within-file collisions
  importId             String
  matchStatus          String             @default("unmatched") // unmatched | matched
  refText              String             @default("") // manual refs (cheque no. / บิล 38/13 / Shopee / RE list) — non-empty marks matched
  expressConfirmedAt   DateTime?
  expressConfirmedById String?
  matches              PaymentBankMatch[]

  @@index([txnAt])
  @@index([matchStatus])
  @@index([direction])
}

// Links a Payment to a BankTxn credit line. Many-to-many via this join table (both sides
// are Juno-owned models, so real FK relations are used here — unlike Diana's read-only
// cross-deity string refs into Product/Customer below).
model PaymentBankMatch {
  id          String   @id @default(cuid())
  paymentId   String
  payment     Payment  @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  bankTxnId   String
  bankTxn     BankTxn  @relation(fields: [bankTxnId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  createdById String?

  @@unique([paymentId, bankTxnId])
  @@index([paymentId])
  @@index([bankTxnId])
}

// ─── Juno RE reconciliation (the "future RE-import" the WHT task exposed grossOf() for) ──
// One row per Express AR-receipt (ARRCPDAT "RE#######"). The CEO imports the periodic
// ARRCPDAT.TXT export (see POST /api/juno/re/import); each receipt is upserted by reNumber
// so a re-import just refreshes amount/customer/etc. rather than duplicating. Match status
// against Payment.reNumbers is COMPUTED LIVE on read (GET /api/juno/re) — never stored here —
// so it's always current against whatever Payments exist at query time. See JUNO_BRIEF.md.
model ReReceipt {
  id           String   @id @default(cuid())
  reNumber     String   @unique // bare 7-digit core (ARRCPDAT "RE6907402" -> "6907402")
  receiptDate  String   @default("") // dd/mm/yy as printed (Thai Buddhist), kept as-typed like Payment.transferAt
  customerName String   @default("")
  salesName    String   @default("")
  amount       String   @default("") // ยอดตามใบกำกับ (gross/invoice total) — house String-money style, matches Payment.amount
  notPosted    Boolean  @default(false) // "***" in the report's หมายเหตุ column (ทำรายการรับชำระหนี้ไม่เรียบร้อย)
  invoices     Json? // ReReceiptInvoice[] (docNo/date/amount) — the IV/SR detail lines under this receipt, display-only
  importedAt   DateTime @default(now()) // when this row was last imported/refreshed
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([notPosted])
}

// Juno manual-bill lane. These documents cover non-Express sales and are linked to incoming
// Payment rows live through Payment.billNos (the same denormalized-list pattern as REs).
model ManualBill {
  id            String    @id @default(cuid())
  billNo        String    @unique
  billedAt      String    @default("")
  customerCode  String    @default("") // optional Express customer code (walk-ins leave blank)
  buyerName     String    @default("")
  buyerPhone    String    @default("")
  buyerAddress  String    @default("")
  items         Json?
  amount        String    @default("")
  note          String    @default("")
  status        String    @default("open")
  voidedAt      DateTime?
  voidedById    String?
  createdAt     DateTime  @default(now())
  createdById   String?
  createdByName String    @default("")
  updatedAt     DateTime  @updatedAt

  @@index([status])
  @@index([createdAt])
}

// Staff quick-reply templates — canned messages (address, hours, payment, catalog,
// shipping…) the team inserts with one click. Editable in the console.
model QuickReply {
  id        String   @id @default(cuid())
  label     String
  body      String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
}

// Product catalog — extracted from the Prominent PDF catalogue via vision.
// price=0 means "unknown" (the AI must NOT quote it; defer to staff). Variant
// SKUs (color/size) share a photo via photoSku (resolved to the cell's lead SKU).
model Product {
  sku                 String    @id // e.g. "07-10-09"
  nameEn              String    @default("")
  nameTh              String    @default("")
  price               Int       @default(0) // baht; 0 = unknown
  promo               String    @default("") // e.g. "ซื้อ 9 แถม 1"
  note                String    @default("") // pack/size/weight
  page                Int? // catalog page
  photoSku            String? // SKU whose photo file represents this product (self or lead variant)
  keywords            String[] // search terms (tokenized names) for matching
  status              String    @default("active") // active | archived
  stock               Int? // remaining quantity from the latest stock snapshot (null = unknown)
  stockAt             DateTime? // the date the stock figure is as-of (snapshot date)
  // Vesta low-stock threshold (null = no threshold set). Low = stock != null && stock <= reorderPoint.
  reorderPoint        Int?
  // Merchandising group key (see api/src/stock/catalogGroups.ts), e.g. "acrylic" | "endo".
  // null = not yet assigned. Independent of the Express category in the SKU.
  catalogGroup        String?
  // Sub-group 2-letter code WITHIN the group (e.g. "AL" alginate under impression). null =
  // none. The product code becomes group + subgroup + number → "IMAL01".
  catalogSubgroup     String?
  // ── Name-normalization review (Vesta ตรวจทาน tab) ──────────────────────
  // A STAGED normalized English name awaiting supervisor review. The live nameEn is left
  // untouched until the proposal is APPROVED in-app; approving copies proposedNameEn → nameEn.
  // Seeded from api/src/catalog/nameProposals.ts via POST /api/stock/proposals/load.
  proposedNameEn      String? // the normalized candidate (null = no proposal loaded)
  proposalStatus      String    @default("none") // none | pending | approved | rejected
  proposalNeedsReview Boolean   @default(false) // flagged for team review (e.g. ambiguous shade code)
  updatedAt           DateTime  @updatedAt

  @@index([status])
  @@index([catalogGroup])
  @@index([proposalStatus])
}

// Short human-friendly code per product (e.g. "TR34") that resolves to the canonical SKU.
// Products in the same family ("NN-NN") share a prefix; alias = prefix + item segment.
// Display + search only — Product.sku stays the shared key. See api/src/stock/aliases.ts.
model ProductAlias {
  sku       String   @id // one alias per product; PK = canonical Product.sku
  alias     String   @unique // UPPERCASE, globally unique (e.g. "TR34")
  groupKey  String // the family "NN-NN"
  prefix    String // the group's prefix (alias = prefix + 3rd segment)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([groupKey])
}

// User-created catalog groups + sub-groups (Vesta จัดกลุ่ม tab). These OVERLAY the built-in
// vocabulary hardcoded in api/src/stock/catalogGroups.ts — the merged view is loaded by
// stock/taxonomy.ts. Built-ins live in code (they can never disappear); only staff-created ones
// are stored here. A custom sub-group may attach to ANY group (built-in or custom) via groupKey.
model CatalogGroupDef {
  key       String   @id // stable slug (e.g. "cg_zx"); never collides with a built-in key
  code      String   @unique // 2-letter product-code prefix (globally unique across built-in + custom)
  nameTh    String   @default("")
  nameEn    String   @default("")
  pillar    String   @default("lab") // lab | digital | clinical | equipment | review
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
}

model CatalogSubgroupDef {
  id              String   @id @default(cuid())
  groupKey        String // the parent group (built-in key or a CatalogGroupDef.key)
  code            String // 2-letter, unique WITHIN its group
  nameTh          String   @default("")
  nameEn          String   @default("")
  replacesBuiltin String?
  sortOrder       Int      @default(0)
  createdAt       DateTime @default(now())

  @@unique([groupKey, code])
  @@index([groupKey])
}

// ─── Vesta (stock management) ───────────────────────────────────────────
// Vesta writes Product.stock/stockAt on each daily Express CSV import and on
// manual corrections; Minerva reads those same rows. These two tables give
// cheap accountability (who imported / who edited) without a full movements
// ledger (deferred past v1). See docs/VESTA_BRIEF.md.

// Audit of each daily Express CSV import.
model StockImport {
  id            String   @id @default(cuid())
  importedAt    DateTime @default(now())
  importedBy    String? // agent id
  fileName      String   @default("")
  rowsParsed    Int      @default(0)
  skusUpdated   Int      @default(0)
  skusUnmatched Int      @default(0) // CSV SKUs not in the catalog
  note          String   @default("")
}

// Audit of manual stock edits (mirrors Minerva's FinanceAudit pattern).
model StockAdjustment {
  id        String   @id @default(cuid())
  sku       String
  fromQty   Int?
  toQty     Int?
  reason    String   @default("")
  byAgentId String?
  at        DateTime @default(now())

  @@index([sku])
}

// ─── Diana (B2B website — prominentdental.com) ───────────────────────────
// Diana is a 3rd reader of the shared catalog. It READS Product (name/price/
// stock/photo) and NEVER writes it — these tables are Diana-owned and additive
// only (guardrail: ADD only, never alter Minerva/Vesta columns). There are
// deliberately NO Prisma relations into Product/Customer: a relation would force
// a back-reference field onto those Minerva-owned models. Instead Diana stores
// `sku` and the Express customer `code` as plain strings. See docs/DIANA_BRIEF.md.

// A clinic/lab web login. Registration is open; Prominent approves manually.
// Prices, live stock, and the cart are gated behind status == "approved".
model ClinicAccount {
  id            String     @id @default(cuid())
  email         String     @unique
  passwordHash  String
  // clinic/lab identity for approval review + invoicing
  clinicName    String     @default("")
  contactName   String     @default("")
  phone         String     @default("")
  // approval gate: pending → approved (can see prices/order) | rejected
  status        String     @default("pending") // pending | approved | rejected
  approvedAt    DateTime?
  approvedBy    String? // agent id who approved/rejected
  rejectNote    String     @default("")
  // optional soft link to a Minerva/Express customer (e.g. "ร103"). Plain string,
  // not a relation — Diana web identity is separate from LINE identity in v1;
  // reconcile (same clinic, two channels) later. null = unlinked.
  customerCode  String?
  // PDPA: explicit consent captured at registration (Thailand compliance).
  pdpaConsentAt DateTime?
  createdAt     DateTime   @default(now())
  lastLoginAt   DateTime?
  orders        WebOrder[]

  @@index([status])
}

// An order-REQUEST (v1 has no online payment): the clinic submits a cart,
// Prominent confirms price + stock, then invoices and hands off to Express.
model WebOrder {
  id              String         @id @default(cuid())
  clinicAccountId String
  clinicAccount   ClinicAccount  @relation(fields: [clinicAccountId], references: [id])
  // submitted → confirmed (price/stock checked) → invoiced (Express) | cancelled
  status          String         @default("submitted") // submitted | confirmed | invoiced | cancelled
  note            String         @default("") // free-text request note from the clinic
  // Tax-invoice (ใบกำกับภาษี) capture — mirrors Minerva's finance flow. Filled at
  // request time or on confirm; flows to Express (no live API → file import).
  taxName         String         @default("")
  taxAddress      String         @default("")
  taxId           String         @default("")
  confirmedAt     DateTime?
  confirmedBy     String? // agent id
  invoicedAt      DateTime?
  createdAt       DateTime       @default(now())
  // Human-readable, monotonic order number shown as WD-00001 (additive; SERIAL backfills existing rows).
  orderNo         Int            @unique @default(autoincrement())
  lines           WebOrderLine[]

  @@index([clinicAccountId])
  @@index([status])
}

// One requested product line. unitPrice is SNAPSHOTTED from Product.price at
// submission time (baht) — this is what makes tiered pricing a pure phase-2 add:
// orders already record "the price this customer saw", so a future CustomerPrice
// layer changes how the snapshot is computed, not the order schema. nameSnapshot
// preserves the catalog name as ordered, even if the catalog later changes.
model WebOrderLine {
  id           String   @id @default(cuid())
  orderId      String
  order        WebOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  sku          String // references Product.sku (no FK — see section note)
  nameSnapshot String   @default("")
  qty          Int      @default(1)
  unitPrice    Int      @default(0) // baht, snapshot of Product.price at submission (0 = was unknown)

  @@index([orderId])
  @@index([sku])
}

// SEO/credibility enrichment for the PUBLIC catalog — brand, category, and richer
// copy that the shared Product table doesn't carry. Diana-owned and keyed by sku
// (plain string, no FK into Product — same reasoning as the section note above).
// Diana LEFT-JOINs this onto Product by sku; a missing row just means "not enriched
// yet". `source` distinguishes the bulk keyword-derived pass from staff hand-edits
// so a re-derive never clobbers manual work.
model ProductEnrichment {
  sku           String   @id // references Product.sku
  brand         String   @default("")
  category      String   @default("") // Thai category label (facet/filter)
  categoryEn    String   @default("") // English category (SEO/URLs)
  descriptionTh String   @default("")
  descriptionEn String   @default("")
  specs         String[] // bullet-point specs
  source        String   @default("derived") // derived | manual
  updatedBy     String? // agent id who last edited (manual)
  updatedAt     DateTime @updatedAt

  @@index([brand])
  @@index([category])
}

// ─── Ceres (expenses & petty cash) ─── money OUT; append-only; String baht amounts
// (sums parse on read); see docs/CERES_BRIEF.md

model CeresParty {
  id         String  @id @default(cuid())
  name       String  @unique // ต้า, อาร์ม, … or carrier bucket J&T, LALAMOVE Prom …
  kind       String  @default("person") // person | carrier
  agentEmail String? // login link for persons (m-<slug>@prominent.local)
  active     Boolean @default(true)
  sortOrder  Int     @default(0)
}

model CashAccount {
  id   String @id // literal ids: "pettyCash", "bank"
  name String @default("")
}

model CashMovement {
  id            String   @id @default(cuid())
  accountId     String   @default("pettyCash")
  type          String // deposit | advance | refund | topup
  partyId       String?
  partyName     String   @default("") // snapshot
  entity        String   @default("") // PROM | DENL | "" (movements need no entity)
  amount        String   @default("")
  note          String   @default("")
  createdById   String?
  createdByName String   @default("")
  createdAt     DateTime @default(now())

  @@index([accountId, createdAt])
  @@index([partyId])
  @@index([type])
}

model CeresExpense {
  id              String    @id @default(cuid())
  partyId         String?
  partyName       String    @default("")
  enteredById     String?
  enteredByName   String    @default("")
  entity          String    @default("PROM") // PROM | DENL
  category        String    @default("")
  customerNote    String    @default("") // "ลูกค้า: X" for shipping categories
  amount          String    @default("")
  spentAt         DateTime  @default(now())
  receiptUploadId String?
  receiptSha      String    @default("") // sha256 of the receipt image (duplicate detection)
  ocrAmount       String    @default("")
  ocrVendor       String    @default("")
  ocrDate         String    @default("")
  status          String    @default("pending") // pending | approved | settled | rejected | void
  approvedById    String?
  approvedAt      DateTime?
  rejectReason    String    @default("")
  // void = soft-delete by gm/ceo; the row is kept (struck-through, excluded from every
  // total/board/settlement) so a closed day's books stay auditable. Never hard-deleted.
  voidedById      String?
  voidedAt        DateTime?
  voidReason      String    @default("")
  settlementId    String?
  aiVerdict       String    @default("") // "" | ok | flagged (post-hoc AI review, wired later)
  aiReviewId      String?
  note            String    @default("")
  createdAt       DateTime  @default(now())

  @@index([status])
  @@index([partyId])
  @@index([settlementId])
  @@index([createdAt])
  @@index([receiptSha])
}

model CeresRevision {
  id            String   @id @default(cuid())
  subjectType   String // expense | paymentRequest
  subjectId     String
  changedById   String?
  changedByName String   @default("")
  before        Json
  after         Json
  reason        String   @default("")
  createdAt     DateTime @default(now())

  @@index([subjectType, subjectId])
}

model CeresSettlement {
  id           String                @id @default(cuid())
  dayKey       String                @unique // Thai day "YYYY-MM-DD"; one close per day
  closedById   String?
  closedByName String                @default("")
  boxBefore    String                @default("") // box balance before close (computed snapshot)
  boxAfter     String                @default("")
  note         String                @default("")
  createdAt    DateTime              @default(now())
  lines        CeresSettlementLine[]
}

model CeresSettlementLine {
  id           String          @id @default(cuid())
  settlementId String
  settlement   CeresSettlement @relation(fields: [settlementId], references: [id])
  partyId      String?
  partyName    String          @default("")
  advances     String          @default("") // since previous settlement
  expenses     String          @default("")
  refunds      String          @default("")
  outstanding  String          @default("") // carried forward

  @@index([settlementId])
  @@index([partyId])
}

model CeresPaymentRequest {
  id                  String    @id @default(cuid())
  requestedById       String?
  requestedByName     String    @default("")
  entity              String    @default("PROM")
  payee               String    @default("")
  category            String    @default("")
  amount              String    @default("")
  detail              String    @default("")
  recurringTemplateId String?
  billPeriod          String    @default("") // e.g. "2026-06" for recurring
  status              String    @default("requested") // requested | ai_approved | escalated | ceo_approved | rejected | cancelled | paid
  aiReviewId          String?
  decidedById         String?
  decidedAt           DateTime?
  decisionNote        String    @default("")
  paidById            String?
  paidAt              DateTime?
  paidRef             String    @default("")
  createdAt           DateTime  @default(now())

  @@index([status])
  @@index([recurringTemplateId])
  @@index([createdAt])
}

model CeresRecurringTemplate {
  id             String   @id @default(cuid())
  payee          String
  entity         String   @default("PROM")
  category       String   @default("")
  expectedAmount String   @default("")
  tolerancePct   Int      @default(15)
  period         String   @default("monthly") // monthly | quarterly | yearly
  dueDay         Int      @default(1)
  graceDays      Int      @default(5)
  active         Boolean  @default(true)
  note           String   @default("")
  createdAt      DateTime @default(now())
}

model CeresAIReview {
  id            String   @id @default(cuid())
  subjectType   String // expense | paymentRequest
  subjectId     String
  verdict       String // approve | flag | escalate | error
  reasoning     String   @default("")
  policyVersion String   @default("")
  model         String   @default("")
  createdAt     DateTime @default(now())

  @@index([subjectType, subjectId])
}

model CeresStatementImport {
  id           String   @id @default(cuid())
  fileName     String   @default("")
  sha256       String   @default("")
  periodFrom   String   @default("")
  periodTo     String   @default("")
  rowsParsed   Int      @default(0)
  linesNew     Int      @default(0)
  linesDup     Int      @default(0)
  excluded     Int      @default(0)
  importedById String?
  importedAt   DateTime @default(now())
}

model CeresStatementLine {
  id             String    @id @default(cuid())
  importId       String
  txnAt          DateTime
  amount         String    @default("")
  direction      String    @default("in") // in | out
  channel        String    @default("")
  description    String    @default("")
  details        String    @default("")
  payerName      String    @default("")
  payerBank      String    @default("")
  dedupeKey      String    @unique
  matchStatus    String    @default("unmatched") // unmatched | matched
  matchedType    String    @default("") // paymentRequest | cashMovement | ""
  matchedId      String    @default("")
  refText        String    @default("")
  reconciledById String?
  reconciledAt   DateTime?

  @@index([txnAt])
  @@index([matchStatus])
  @@index([direction])
}

model CeresCategory {
  id                String  @id @default(cuid())
  name              String  @unique
  kind              String  @default("general") // shipping | fuel | toll | general
  ceiling           String  @default("") // per-item baht ceiling for AI policy; "" = none
  needsCustomerNote Boolean @default(false)
  active            Boolean @default(true)
  sortOrder         Int     @default(0)
}

// ─── Mercury (procurement / buy-side) — CLOUD node tables only ───────────
// Cloud-Mercury is the team/phone-facing reorder board (mirror of Vesta on the buy side).
// SECRETS-FREE BY CONSTRUCTION: these rows carry NO vendor, cost, real name, or real SKU — a
// full dump of this DB reveals only aliases + quantities + who-ordered, never a supplier
// identity or a price. Vendor/SecretMap/PurchaseOrder live ONLY in the separate local-Mercury
// DB (Phase 2) and are never migrated into this shared schema. See docs/MERCURY_BRIEF.md §3/§5/§8.
model MercuryItem {
  id          String   @id @default(cuid())
  displayName String // ordinary item name OR an opaque alias ("วัตถุดิบ A-17"); never the real name
  isSecret    Boolean  @default(false) // secret items resolve to a real vendor ONLY in local-Mercury
  vestaSku    String? // dashed Product.sku for ordinary stocked items; NULL for secret items
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())

  @@index([active])
}

// A team purchase REQUEST (item/alias + qty). Non-secret. Local-Mercury pulls pending rows,
// resolves aliases → real vendor locally, and flows status back (ordered/received/cancelled).
model MercuryRequest {
  id            String    @id @default(cuid())
  itemId        String // → MercuryItem.id (bare FK column, house style — no @relation)
  qty           String    @default("") // Juno/suite number-as-String convention
  requestedById String? // → Agent.id (bare column, NOT @relation — mirrors Payment.salesAgentId etc.)
  note          String    @default("")
  status        String    @default("pending") // pending | ordered | received | cancelled
  createdAt     DateTime  @default(now())
  orderedAt     DateTime?
  receivedAt    DateTime?

  @@index([status])
}

// ─── Venus (360° customer CRM) ─── Stage A+B: backend foundation only.
// See docs/VENUS_BRIEF.md. Express's customer master ("ARMAST") is a DIFFERENT,
// larger population than Customer (which is LINE-keyed — code is nullable/non-unique,
// only set for chat customers staff tagged). VenusCustomer is keyed on the Express
// code itself and soft-links to Customer BY VALUE (code), never a FK — Customer.code
// isn't unique so a real FK isn't possible, and we don't want an import to ever be
// blocked by Customer-side data quality.
model VenusCustomer {
  id              String   @id @default(cuid())
  code            String   @unique // Express customer code, as-is (e.g. "A001", "Cก002", "๙๙0000006")
  // lowercased + dash-stripped code, for dash-insensitive search (see SKU convention doc)
  searchKey       String
  name            String   @default("")
  nameEn          String?
  custType        String? // ประเภท section this customer was filed under (e.g. ลูกค้าประจำ, ลูกค้าชั่วคราว)
  repCode         String? // พนักงานขาย (salesperson code, e.g. "C1", "C2", "C7") — ragged, may be absent
  zone            String? // เขต
  priceType       String? // ประเภทราคา
  discount        String? // ส่วนลด, kept as printed (may be a %, blank, or free text)
  address         String? // addr1/2/3 joined with ", " (blank segments dropped)
  contact         String? // ผู้ติดต่อ
  phone           String? // โทร.
  acctNo          String? // เลขที่บ/ช
  shipBy          String? // ขนส่งโดย
  creditDays      Int? // เครดิต : N วัน
  creditLimit     String? // วงเงิน, kept as printed (baht string; parses on read like Ceres/Juno money)
  creditTerms     String? // raw เงื่อนไข free text
  creditTermsNorm String? // normalized: CASH | PREPAY | CREDIT | OTHER (see normalizeCreditTerms)
  note            String? // trailing indented free-note lines (e.g. "เงินสด", "+เพิ่มยอด 0.25%")
  importedAt      DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([searchKey])
  @@index([repCode])
  @@index([custType])
}

// Sale document header (Express sales-report import) — Phase 1, defined now so later
// stages drop in without another migration. Soft-links to VenusCustomer by code (same
// non-FK reasoning as above: an unmatched customer code must never block an import).
// Fields below `docType` were added for the OESOC (grouped-by-customer sales order)
// import — additive only, see migration 20260706120000_venus_sales_import.
model SaleDoc {
  id           String     @id @default(cuid())
  docNo        String     @unique
  customerCode String?
  customerId   String? // VenusCustomer.id, once matched
  date         DateTime
  total        String     @default("") // baht string, parses on read (Ceres/Juno convention)
  docType      String? // invoice | credit-note | receipt, etc. — Express-specific, TBD Phase 1
  void         Boolean    @default(false) // leading "*" in Express — cancelled doc, kept not dropped
  repCode      String? // พนักงานขาย (salesperson code)
  goodsValue   String     @default("") // มูลค่าสินค้า, ex-VAT — baht string, same convention as `total`
  vat          String     @default("") // VAT — baht string
  delivered    Boolean? // ส่งหมด (Y/N); null = not stated
  reference    String? // อ้างอิง free-text
  importedAt   DateTime   @default(now())
  lines        SaleLine[]

  @@index([customerCode])
  @@index([date])
}

model SaleLine {
  id        String  @id @default(cuid())
  saleDocId String
  saleDoc   SaleDoc @relation(fields: [saleDocId], references: [id])
  lineNo    Int
  sku       String?
  // product name as printed on the sales report (OESOC line) — the source of truth for
  // what was sold, since ~60% of sold SKUs aren't in the 1187-item Product catalog.
  name      String?
  unit      String? // ชิ้น / กล่อง / ขวด … as printed on the line
  productId String? // Product.sku, once matched
  qty       Float   @default(0)
  unitPrice String  @default("")
  amount    String  @default("")

  @@unique([saleDocId, lineNo])
  @@index([sku])
}

// One row per customer, fully overwritten by the nightly analytics job (derived data,
// not append-only money — see VENUS_BRIEF.md §6). Phase 2 populates this; empty for now.
// `trendOrders`/`reorderDue` added for the RFM/trend/reorder engine — additive only, see
// migration 20260706120000_venus_sales_import.
model CustomerStats {
  id            String    @id @default(cuid())
  customerCode  String    @unique // VenusCustomer.code
  r             Int? // recency: days since last purchase
  f             Int? // frequency: purchase count in window
  m             Float? // monetary: revenue in window
  rfmScore      String? // e.g. "435" (R,F,M quintiles 1-5)
  segment       String? // ลูกค้าชั้นดี | ลูกค้าประจำ | มาใหม่ | เสี่ยงหาย | หายไปแล้ว
  trendPct      Float? // last-90d vs previous-90d revenue % change
  trendDir      String? // up | down | flat
  trendOrders   Int? // last-90d order-count delta vs previous 90d (raw count difference)
  // Reorder-due items: JSON array of { sku, productName, lastPurchase, medianGapDays,
  // dueSince } for consumable SKUs (>=3 purchases) past 1.25x their median reorder cycle.
  // Kept as JSON (not a relation table) — it's fully derived/overwritten each recompute,
  // same as the rest of this row, and queried only per-customer (never filtered across
  // customers), so a relation table would add join cost with no query benefit yet.
  reorderDue    Json?
  // Cross-sell gap signals (VENUS_BRIEF.md §7): JSON array of { crossSku, name, anchorSku,
  // score } — CrossSellLink pairings (learned bought-together, Minerva's picker) where the
  // customer owns the anchorSku but has never bought the crossSku, ranked by score desc.
  // Empty/absent when CrossSellLink has no rows yet or the customer has no gaps — additive,
  // see migration 20260710000000_venus_signals.
  crossSellGaps Json?
  // Big-ticket anniversary signals (VENUS_BRIEF.md §6/§7): JSON array of { sku, name,
  // unitPrice, monthsAgo, lastPurchase } — the SAME one-off-equipment definition used to
  // EXCLUDE these SKUs from reorder cycles (bought exactly once, unit price >
  // EQUIPMENT_PRICE_THRESHOLD), surfaced instead as a positive service/upgrade-timing nudge
  // once aged past VENUS_BIGTICKET_MIN_MONTHS. Additive, see migration
  // 20260710000000_venus_signals.
  bigTicket     Json?
  dataFrom      DateTime? // data-coverage window this row was computed over (min sale date)
  dataTo        DateTime? // data-coverage window this row was computed over (max sale date)
  computedAt    DateTime  @default(now())

  @@index([segment])
}

// Manual pinned "ข้อควรระวัง" note (VENUS_BRIEF.md §7 precaution #4) — one per customer,
// shared-pool free text (any logged-in Venus user — supervisor + granted employees — can
// write; not supervisor-only like imports). Keyed on the Express customer `code`, same
// soft-link convention as SaleDoc.customerCode (no FK — VenusCustomer rows can be
// re-imported/rebuilt independently of notes). Empty text clears the note rather than
// leaving an empty row (see PUT /api/venus/customers/:code/note).
model VenusNote {
  id           String   @id @default(cuid())
  customerCode String   @unique
  text         String
  authorName   String?
  updatedAt    DateTime @updatedAt
}

// Weekly AI suggestion card (VENUS_BRIEF.md §7 "AI cards"). ONE row per customer,
// fully OVERWRITTEN each generator run (derived narration, not an audit ledger — same
// "derived, not append-only" reasoning as CustomerStats). Generated ONLY for customers
// with >=1 active signal (api/src/venus/cards.ts: activeSignals()); the rules layer
// (CustomerStats badges) is the product, this is just the narrator on top — track-and-tell,
// never auto-sent to a customer. `signalsJson` stores the EXACT signal list the card text
// was built from, for audit (so a rep/supervisor can see what the AI was and wasn't told —
// it may only restate these, never invent numbers/prices/products, see cards.ts). Keyed on
// the Express customer `code`, same soft-link convention as VenusNote/SaleDoc (no FK).
model VenusCard {
  id           String   @id @default(cuid())
  customerCode String   @unique
  text         String
  signalsJson  Json
  model        String   @default("")
  createdAt    DateTime @default(now())
}

// ─── Jupiter (accounting / consolidation — "the king") ───────────────────
// Jupiter is the GROUP-WIDE accounting layer over every company. Phase 1 is a
// consolidated owner's cockpit + a monthly close pack — NOT yet a double-entry
// ledger (that is Phase 2, when the Appoint Alliance chart of accounts + posting
// land). JupiterCompany FORMALISES the ad-hoc `entity` code already used on
// CeresExpense/CashMovement (today just PROM|DENL) into the full group; JupiterTxn
// is a single-line income/expense record — money as String baht to match
// Payment/CeresExpense's free-text/OCR convention (sums parse on read). Supervisor-only.
model JupiterCompany {
  code      String       @id // group entity code: PROM | TONR | DENC | DENL | KPKF
  name      String       @default("") // Prominent, Tonmai Residence, DentalPort Clinic, …
  nameTh    String       @default("")
  kind      String       @default("") // free label: distribution | property | clinic | lab | fnb …
  color     String       @default("#6D28D9") // dashboard accent (hex)
  taxId     String       @default("") // เลขประจำตัวผู้เสียภาษี (13 digits) — for Phase 3 tax outputs
  vatReg    Boolean      @default(true) // จดทะเบียนภาษีมูลค่าเพิ่ม?
  active    Boolean      @default(true)
  sortOrder Int          @default(0)
  txns      JupiterTxn[]
}

model JupiterTxn {
  id            String         @id @default(cuid())
  companyCode   String // -> JupiterCompany.code (the group entity)
  company       JupiterCompany @relation(fields: [companyCode], references: [code])
  // income (money in) | expense (money out) — the primary axis of the cockpit.
  direction     String         @default("expense") // income | expense
  date          DateTime       @default(now()) // accounting date — the period this falls in
  party         String         @default("") // customer or vendor name (free-text snapshot)
  category      String         @default("") // maps toward the Appoint Alliance CoA in Phase 2
  // money — String baht (matches Payment/CeresExpense). `amount` = the NET received/paid
  // (what the slip/bank shows); vat/wht tracked alongside. "" = none.
  amount        String         @default("")
  vatAmount     String         @default("") // ภาษีขาย (income) / ภาษีซื้อ (expense)
  whtAmount     String         @default("") // หัก ณ ที่จ่าย withheld on this txn
  // Exact-decimal SHADOW of the three String money fields (P2 double-entry precondition —
  // a ledger must balance debit==credit to the satang, which lossy parseFloat sums can't do).
  // Populated on every write from now on; the String fields stay the live read path for Phase 1.
  amountNum     Decimal?       @db.Decimal(14, 2)
  vatNum        Decimal?       @db.Decimal(14, 2)
  whtNum        Decimal?       @db.Decimal(14, 2)
  note          String         @default("")
  // provenance: 'manual' = typed in Jupiter, 'ai' = AI natural-language entry, 'sync:<deity>'
  // = mirrored from another app (juno/ceres/venus) in Phase 1b. sourceRef = the source row id
  // (idempotency key for sync so a re-run never double-books).
  source        String         @default("manual")
  sourceRef     String         @default("")
  createdById   String?
  createdByName String         @default("")
  createdAt     DateTime       @default(now())

  @@index([companyCode, date])
  @@index([direction])
  @@index([source])
  @@index([sourceRef])
}

// OA read-sync — surfaces LINE OA Manager "Read"/"อ่านแล้ว" status inside Minerva.
// The Messaging API has NO outbound read receipts, and the OA Manager uses a DIFFERENT
// per-customer id namespace than the U… ids we store, so a passive Chrome MV3 extension
// in staff's own logged-in browsers reads the open chat's Read marker + OA chat id and
// posts them to POST /api/oa-sync. We map OA chats to our Customer conservatively (unique
// exact name matches only) — customerId stays null when ambiguous (harmless). ADD-ONLY.
model OaReadSync {
  id           String    @id @default(cuid())
  oaChatId     String    @unique // OA-Manager-native customer id (U…32hex)
  customerId   String? // our Customer.id once matched (nullable)
  oaTitle      String? // OA header title (may be an OA-assigned nickname)
  oaSubName    String? // parenthesized/subtitle LINE display name if present
  readLabel    String? // raw marker text e.g. "Read 16:50" / "อ่านแล้ว 16:50"
  readSeenAt   DateTime? // when the extension observed the marker
  reportedById String? // agent who synced
  updatedAt    DateTime  @updatedAt
  createdAt    DateTime  @default(now())

  @@index([customerId])
}

// ─── Party (canonical customer/vendor identity — punch #9) ───────────────
// Today one real customer is forked across up to 4 unlinked rows: Customer (LINE),
// VenusCustomer (Express code), ClinicAccount (Diana email), OaReadSync (OA id) — joined only
// by a free-typed, non-normalised `customerCode` string that silently misses on any drift. Party
// is the canonical spine: ONE row per deduplicated real entity; every external key hangs off
// PartyIdentity, whose @@unique([channel,key]) makes a (channel,key) point at exactly one Party.
// ADDITIVE + NON-INVASIVE: nothing else is rewired yet — existing tables gain an optional
// `partyId` progressively later. Backfill is a run-once script (api/src/scripts/backfillParties),
// never a boot step; keys are normalised (reuse venus toSearchKey for express_code) before insert.
model Party {
  id           String          @id @default(cuid())
  kind         String          @default("customer") // customer | vendor | payee | carrier | staff
  displayName  String          @default("")
  primaryPhone String          @default("") // denormalised best phone (display snapshot, not a key)
  note         String          @default("")
  mergedIntoId String? // soft-merge pointer; non-null ⇒ this row was merged into another Party
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  identities   PartyIdentity[]

  @@index([kind])
  @@index([mergedIntoId])
}

model PartyIdentity {
  id         String   @id @default(cuid())
  partyId    String
  party      Party    @relation(fields: [partyId], references: [id], onDelete: Cascade)
  // line_user | oa_chat | express_code | diana_email | phone | ceres_name | agent_email | vendor_local
  channel    String
  key        String // NORMALISED value (lowercased/dash-stripped code, folded digits, e-mail, …)
  rawKey     String   @default("") // as-entered, pre-normalisation (audit)
  confidence String   @default("confirmed") // confirmed | inferred (name/phone match) | conflict
  source     String   @default("") // which deity/table asserted it
  createdAt  DateTime @default(now())

  // (channel,key) is globally unique — the dedup spine: the same identity can never split
  // across two Parties, and a re-import of an already-known key is idempotent.
  @@unique([channel, key])
  @@index([partyId])
}

