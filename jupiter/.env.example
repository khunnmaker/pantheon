# Jupiter (portal) build-time env. All are baked into the static bundle at `npm run build`,
# so the Railwayâ†’custom-domain cutover (Phase 2) is an env edit + redeploy, not a code change.

# The shared Minerva api that serves /api/auth/login and /api/jupiter/badges.
# Phase 1: the Minerva api's Railway URL. Phase 2: https://api.prominentdental.com
VITE_API_URL=http://localhost:3000

# Where each deity's frontend is served. A tile opens the matching URL (same tab).
# Leave a URL unset to hide that tile even if the role could enter it (e.g. before the
# service exists). Phase 1: each app's Railway URL. Phase 2: https://<deity>.prominentdental.com
VITE_MINERVA_URL=http://localhost:5173
VITE_VULCAN_URL=http://localhost:5174
VITE_JUNO_URL=http://localhost:5176
# Ceres is not live in Phase 1 â€” leave unset until its service and roles ship.
VITE_CERES_URL=
