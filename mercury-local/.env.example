# mercury-local config. Copy to `.env` (which is gitignored). LOCAL machine only.

# SQLite database file (relative to prisma/). Holds ALL secrets — full-disk-encrypt this machine.
DATABASE_URL="file:./mercury-local.db"

# Port the local Express server + browser open on. Fixed 4610 to avoid the suite dev ports (5173-5178).
PORT=4610

# ── SMTP send (Phase 2c) ─────────────────────────────────────────────────────
# The mail credentials live in a gitignored JSON file in THIS folder, not here:
#   .mercury-smtp.json  — { SMTP_USER, SMTP_PASS, ... }  (copy .mercury-smtp.example.json)
# SMTP_PASS is a Google App Password (16 chars) for khunnakritr@prominentdental.com; the From
# header is the verified purchasing@ alias. Full step-by-step: docs/MERCURY_LOCAL_RUNBOOK.md §2.
# (Env vars SMTP_HOST/SMTP_PORT/SMTP_SECURE/SMTP_USER/SMTP_PASS/MAIL_FROM override the file if set,
#  but the JSON config is the normal place — do NOT put SMTP_PASS in a committed .env.)

# Offline pipeline proof (optional): point at a JSON file { "requests": [...], "items": [...] }
# to run sync→resolve→build→PDF→email without a deployed cloud. Leave unset in normal use.
# MERCURY_CLOUD_FIXTURE="./fixture.json"
