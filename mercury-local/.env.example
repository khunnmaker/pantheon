# mercury-local config. Copy to `.env` (which is gitignored). LOCAL machine only.

# SQLite database file (relative to prisma/). Holds ALL secrets — full-disk-encrypt this machine.
DATABASE_URL="file:./mercury-local.db"

# Port the local Express server + browser open on. Fixed 4610 to avoid the suite dev ports (5173-5178).
PORT=4610

# ── Gmail send (Phase 2c) ────────────────────────────────────────────────────
# The Gmail credentials are NOT env vars — they are two gitignored JSON files in this folder:
#   gmail-oauth-client.json  — the OAuth client you download from GCP (client_id/secret)
#   gmail-token.json         — the refresh token, saved after you click "Connect Gmail"
# The OAuth loopback uses port 4620. Full step-by-step: docs/MERCURY_LOCAL_RUNBOOK.md §2.

# Offline pipeline proof (optional): point at a JSON file { "requests": [...], "items": [...] }
# to run sync→resolve→build→PDF→email without a deployed cloud. Leave unset in normal use.
# MERCURY_CLOUD_FIXTURE="./fixture.json"
