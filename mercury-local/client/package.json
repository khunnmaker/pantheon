{
  "name": "mercury-local-client",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Mercury local — React/Vite/Tailwind UI (Vendors, Secret map, Purchase Orders). Served by the local Express server; talks only to localhost.",
  "scripts": {
    "dev": "vite --host --port 4611",
    "build": "tsc -b && vite build",
    "preview": "vite preview --host --port 4611",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "lucide-react": "^0.454.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.2",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.14",
    "typescript": "^5.6.2",
    "vite": "^5.4.9"
  }
}
