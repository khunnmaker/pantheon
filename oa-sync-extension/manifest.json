{
  "manifest_version": 3,
  "name": "Minerva OA Read Sync",
  "version": "0.3.1",
  "description": "Passively syncs LINE OA Manager \"Read\" status of the chat you have open into Minerva. Reads only ids, names and the Read marker — never message content, never LINE credentials.",
  "permissions": ["storage", "tabs"],
  "host_permissions": [
    "https://chat.line.biz/*",
    "https://api.prominentdental.com/*",
    "https://minerva-production-9309.up.railway.app/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://chat.line.biz/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://minerva.prominentdental.com/*",
        "https://heroic-contentment-production-16e7.up.railway.app/*"
      ],
      "js": ["minerva-bridge.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Minerva OA Read Sync"
  }
}
